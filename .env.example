# =========================================================================
# Variáveis de ambiente — copie este arquivo para .env e ajuste se necessário
# Os defaults aqui funcionam para o docker-compose padrão.
# =========================================================================

# ----- Postgres (clients-service) -----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=marketplace
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ----- MongoDB (products-service) -----
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=marketplace

# ----- Cassandra (orders-service) -----
CASSANDRA_CONTACT_POINTS=cassandra
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=marketplace
CASSANDRA_LOCAL_DATACENTER=datacenter1

# ----- Backend services -----
CLIENTS_SERVICE_PORT=3001
PRODUCTS_SERVICE_PORT=3002
ORDERS_SERVICE_PORT=3003

# Cross-service URLs (visto de dentro do docker-compose network)
CLIENTS_SERVICE_URL=http://clients-service:3001
PRODUCTS_SERVICE_URL=http://products-service:3002

# ----- Frontend -----
# Visto pelo browser, então usa localhost (host)
VITE_CLIENTS_URL=http://localhost:3001
VITE_PRODUCTS_URL=http://localhost:3002
VITE_ORDERS_URL=http://localhost:3003

# ----- Observabilidade -----
LOG_LEVEL=info
NODE_ENV=development
