# =========================================================================
# Variáveis de ambiente — copie para .env e ajuste.
#
# Existem DOIS modos suportados:
#
# 1) MODO DOCKER COMPLETO (8 GB RAM, virtualização habilitada)
#    → use as variáveis da seção "LOCAL" abaixo. Os defaults já apontam
#      para os containers do docker-compose.yml.
#
# 2) MODO CLOUD (zero Docker; ideal para máquinas modestas)
#    → preencha as variáveis da seção "CLOUD" e rode `npm run dev:local`.
# =========================================================================


# ========== LOCAL (modo Docker Compose) ==========

# Postgres (clients-service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=marketplace
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# MongoDB (products-service)
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=marketplace

# Cassandra (orders-service)
CASSANDRA_CONTACT_POINTS=cassandra
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=marketplace
CASSANDRA_LOCAL_DATACENTER=datacenter1


# ========== CLOUD (modo serviços local + bancos free tier) ==========
# Quando preenchidas, sobrescrevem as variáveis locais correspondentes.

# Supabase / Neon / Render / qualquer Postgres com URL completa.
# Exemplo: postgresql://USER:PASS@db.xxxx.supabase.co:5432/postgres?sslmode=require
# DATABASE_URL=

# MongoDB Atlas — Connection String SRV.
# Exemplo: mongodb+srv://user:pass@cluster0.xxx.mongodb.net/marketplace?retryWrites=true&w=majority
# MONGO_URL=

# DataStax Astra DB.
# 1. Baixe o Secure Connect Bundle do Astra e salve em ./infra/cassandra/astra/
# 2. Gere um Application Token com role "Database Administrator"
# ASTRA_BUNDLE_PATH=./infra/cassandra/astra/secure-connect-marketplace.zip
# ASTRA_APPLICATION_TOKEN=AstraCS:xxxxxxxxxxxxxxxxxxxx:xxxxxxxxxxxxxxxxxxxx
# CASSANDRA_KEYSPACE=marketplace


# ========== Backend services (portas + URLs cross-service) ==========

CLIENTS_SERVICE_PORT=3001
PRODUCTS_SERVICE_PORT=3002
ORDERS_SERVICE_PORT=3003

# URLs vistas DE DENTRO da rede (docker-compose). Em modo local-host use http://localhost:PORT.
CLIENTS_SERVICE_URL=http://localhost:3001
PRODUCTS_SERVICE_URL=http://localhost:3002


# ========== Frontend (visto pelo browser → sempre localhost) ==========

VITE_CLIENTS_URL=http://localhost:3001
VITE_PRODUCTS_URL=http://localhost:3002
VITE_ORDERS_URL=http://localhost:3003


# ========== Observabilidade ==========

LOG_LEVEL=info
NODE_ENV=development
