{
  "name": "marketplace-polyglot",
  "version": "0.1.0",
  "private": true,
  "description": "Marketplace com Persistência Poliglota — Postgres + MongoDB + Cassandra",
  "workspaces": [
    "services/clients-service",
    "services/products-service",
    "services/orders-service",
    "frontend"
  ],
  "scripts": {
    "up": "docker compose up --build",
    "up:detach": "docker compose up --build -d",
    "down": "docker compose down",
    "down:clean": "docker compose down -v",
    "logs": "docker compose logs -f",
    "ps": "docker compose ps",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "compose:check": "docker compose config",
    "psql": "docker compose exec postgres psql -U postgres -d marketplace",
    "mongosh": "docker compose exec mongo mongosh marketplace",
    "cqlsh": "docker compose exec cassandra cqlsh",
    "dev:local": "concurrently -k -n CLIENTS,PRODUCTS,ORDERS,FRONTEND -c blue,green,magenta,yellow \"npm:dev:clients\" \"npm:dev:products\" \"npm:dev:orders\" \"npm:dev:frontend\"",
    "dev:clients": "npm --workspace clients-service run start:dev",
    "dev:products": "npm --workspace products-service run start:dev",
    "dev:orders": "npm --workspace orders-service run start:dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "astra:init": "node infra/cassandra/apply-astra-init.js"
  },
  "devDependencies": {
    "cassandra-driver": "^4.7.2",
    "concurrently": "^9.0.1",
    "dotenv": "^16.4.5"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "license": "MIT"
}
